# ── Ambiente ─────────────────────────────────────────────────────────────────
# "production" ativa validações extras (WEBHOOK_API_KEY, CORS_ORIGIN, ADMIN_EMAILS obrigatórios)
# e oculta detalhes de erros 5xx nas respostas da API.
NODE_ENV=production

# Porta em que o Fastify vai escutar. Em VPS fica atrás do Nginx, nunca exposta diretamente.
PORT=3000

# Interface de rede que o Fastify vai bindar. "0.0.0.0" aceita todas as interfaces.
HOST=0.0.0.0

# ── Supabase ──────────────────────────────────────────────────────────────────
# URL do seu projeto Supabase (encontrada em Project Settings > API).
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave de serviço (service_role) — bypassa RLS, nunca exponha ao browser.
# Encontrada em Project Settings > API > service_role key.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── MemberKit ────────────────────────────────────────────────────────────────
# Chave de API do MemberKit (usada como ?api_key= em cada request à API deles).
MEMBERKIT_API_KEY=

# URL base da API REST do MemberKit. Só altere se a MemberKit mudar o endereço.
MEMBERKIT_API_URL=https://app.memberkit.com.br/api/v1

# ── Segurança ────────────────────────────────────────────────────────────────
# Chave secreta enviada pela MemberKit como ?api_key= na URL do webhook.
# Configure o mesmo valor no painel da MemberKit em "Webhooks".
# Obrigatório em produção — sem isso qualquer pessoa pode forjar eventos.
WEBHOOK_API_KEY=

# Origem(ns) do frontend que pode chamar esta API (cabeçalho CORS Access-Control-Allow-Origin).
# Separe múltiplas origens por vírgula: https://dash.exemplo.com,https://admin.exemplo.com
# Obrigatório em produção — sem isso o navegador bloqueia todas as chamadas cross-origin.
CORS_ORIGIN=https://seu-dominio.com

# E-mails dos administradores separados por vírgula.
# Apenas usuários com esses e-mails podem chamar as rotas POST /api/sync/*.
# Obrigatório em produção — sem isso qualquer usuário autenticado pode disparar um sync completo.
ADMIN_EMAILS=seu@email.com

# ── Frontend → Backend ───────────────────────────────────────────────────
# URL que o Next.js usa server-side para chamar o backend Fastify.
# Em Docker, usar o nome do serviço definido no docker-compose (não localhost).
# Em dev local, usar http://localhost:3000.
BACKEND_URL=http://memberkitsync:3000

# ── Logs ─────────────────────────────────────────────────────────────────────
# Nível mínimo de log gravado. Em produção use "info" ou "warn".
# Opções: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
